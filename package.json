{
  "name": "comfyui-nynxz-experimental",
  "private": true,
  "type": "module",
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@comfyorg/comfyui-frontend-types": "^1.22.1",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.3.5",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"*.{js,mts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue}\" \"*.{js,mts,json}\""
  }
